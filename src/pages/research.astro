---
import Base from '../layouts/Base.astro';
import PubEntry from '../components/PubEntry.astro';
import publications from '../data/publications.yaml';
import workingPapers from '../data/working-papers.yaml';
import wip from '../data/work-in-progress.yaml';

// CSS-only tabs (radio inputs + :checked selectors) — no JS, no third-party requests.
const tabs = [
  { id: 'pub', label: 'Publications', items: publications },
  { id: 'wp', label: 'Working papers', items: workingPapers },
  { id: 'wip', label: 'Work in progress', items: wip },
];
---

<Base title="Research" description="Publications and working papers by Marcel Olbert on disclosure regulation, corporate taxation, and corporate finance.">
  <div class="wrap-text">
    <h1 class="page-title">Research</h1>
    <p class="page-lede">
      My work studies how firms respond to taxation, disclosure, and related economic
      policies, typically using large firm-level datasets and combining approaches from
      public economics, finance, and accounting research. My work is regularly published
      in leading academic journals across fields.
    </p>

    <div class="research-tabs">
      <input class="research-radio" type="radio" name="rtab" id="rtab-pub" checked />
      <input class="research-radio" type="radio" name="rtab" id="rtab-wp" />
      <input class="research-radio" type="radio" name="rtab" id="rtab-wip" />

      <div class="research-tablist" role="tablist" aria-label="Research categories">
        {tabs.map((t) => (
          <label class="research-tab" for={`rtab-${t.id}`}>
            {t.label} <span class="research-count">{t.items.length}</span>
          </label>
        ))}
      </div>

      {tabs.map((t) => (
        <div class="research-panel" data-tab={t.id}>
          {t.items.map((pub: any) => <PubEntry pub={pub} />)}
        </div>
      ))}
    </div>
  </div>
</Base>
