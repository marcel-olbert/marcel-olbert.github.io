---
import Base from '../layouts/Base.astro';
import PubEntry from '../components/PubEntry.astro';
import site from '../data/site.yaml';
import news from '../data/news.yaml';
import podcast from '../data/podcast.yaml';
import publications from '../data/publications.yaml';

const latestEpisode = podcast.episodes[0];

const selected = publications.filter((p: any) => p.selected);
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function formatDate(d: string) {
  if (!d) return '';
  const [y, m] = String(d).split('-');
  return m ? `${monthNames[Number(m) - 1]} ${y}` : y;
}
---

<Base>
  <div class="wrap">
    <div class="hero">
      <div>
        <div class="kicker">{site.title} · {site.institution}</div>
        <h1>{site.name}</h1>
        <p class="tagline">{site.tagline}</p>
        <ul class="hero-highlights">
          {site.highlights.map((h: any) => (
            <li><a href={h.url}>{h.text}</a></li>
          ))}
        </ul>
        <div class="hero-actions">
          <a class="btn btn-primary" href={podcast.links.apple}>Podcast</a>
          <a class="btn btn-ghost" href={site.linkedinUrl}>LinkedIn</a>
          <a class="btn btn-ghost" href={site.cvUrl}>CV</a>
          <a class="btn btn-ghost" href={site.ssrnUrl}>SSRN</a>
        </div>
      </div>
      <div class="hero-photo">
        <img src={site.photo} alt={`${site.name}, ${site.title} at ${site.institution}`} width="1600" height="1066" fetchpriority="high" />
      </div>
    </div>

    <section>
      <div class="feature-band">
        <a class="feature-band-media" href={site.cobra.url}>
          <img src={site.cobra.photo} alt={`${site.cobra.name} — ${site.cobra.fullName}`} width="1400" height="933" loading="lazy" />
        </a>
        <div>
          <div class="kicker">Research Center · {site.cobra.role}</div>
          <h2 class="feature-band-title"><a href={site.cobra.url}>{site.cobra.name} — {site.cobra.fullName}</a></h2>
          <p class="feature-band-tagline">{site.cobra.tagline}</p>
          <p class="feature-band-text">{site.cobra.description}</p>
          <p class="feature-band-links">
            <a href={site.cobra.url}>Visit COBRA →</a> · <a href={site.cobra.eventsUrl}>Events</a> · <a href="/events/">Events I host</a>
          </p>
        </div>
      </div>
    </section>

    <section>
      <h2>Latest</h2>
      {news.map((item: any) => (
        <div class="news-item">
          <div class="news-date">{formatDate(item.date)}</div>
          <div>
            {item.text}
            {item.link && <> <a href={item.link}>{item.linkLabel ?? 'Link'}</a></>}
          </div>
        </div>
      ))}
      <p class="follow-line">
        {site.linkedinPitch} <a href={site.linkedinUrl}>Follow on LinkedIn →</a>
      </p>
    </section>

    <section>
      <div class="podcast-band">
        <a href="/podcast/" class="podcast-cover">
          <img src={podcast.cover} alt={`${podcast.name} podcast cover`} width="1200" height="1200" loading="lazy" />
        </a>
        <div>
          <div class="kicker">Podcast · {podcast.tagline}</div>
          <h2 class="podcast-band-title"><a href="/podcast/">{podcast.name}</a></h2>
          <p class="podcast-band-blurb">{podcast.blurb}</p>
          <p class="podcast-latest">
            <strong>Latest episode:</strong> <span lang="de">{latestEpisode.title}</span><br />
            Listen on <a href={latestEpisode.spotify}>Spotify</a> · <a href={latestEpisode.youtube}>YouTube</a> · <a href={podcast.links.apple}>Apple Podcasts</a> · <a href="/podcast/">All episodes →</a>
          </p>
        </div>
      </div>
    </section>

    <section>
      <h2>Selected publications</h2>
      {selected.map((pub: any) => <PubEntry pub={pub} />)}
      <p style="margin-top: 1rem;"><a href="/research/">All publications and working papers →</a></p>
    </section>

    <section>
      <h2>Roles &amp; affiliations</h2>
      <ul style="margin-left: 1.1rem;">
        {site.roles.map((r: string) => <li>{r}</li>)}
      </ul>
      <p style="margin-top: 0.8rem; color: var(--muted);">{site.grants}</p>
    </section>
  </div>
</Base>
